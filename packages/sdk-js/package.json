{
  "name": "@telerithm/sdk",
  "version": "0.1.0",
  "description": "Telerithm client SDK for JavaScript / TypeScript — ship structured logs, errors, and breadcrumbs to a Telerithm backend.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LanNguyenSi/telerithm.git",
    "directory": "packages/sdk-js"
  },
  "homepage": "https://github.com/LanNguyenSi/telerithm/tree/master/packages/sdk-js#readme",
  "bugs": "https://github.com/LanNguyenSi/telerithm/issues",
  "keywords": [
    "telerithm",
    "logging",
    "logs",
    "observability",
    "telemetry",
    "error-tracking",
    "sdk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
