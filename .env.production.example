# Production Environment Variables
# Copy to .env.production and fill in real values

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# OpenAI (optional - for AI Query Engine)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Logging
LOG_LEVEL=info

# CORS (automatically set to https://logs.opentriologue.ai in docker-compose.traefik.yml)
# CORS_ORIGINS=https://logs.opentriologue.ai

# Public API URL (automatically set in docker-compose.traefik.yml)
# PUBLIC_API_URL=https://logs.opentriologue.ai/api/v1
